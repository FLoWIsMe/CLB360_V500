# ─── Peplink InControl2 (GPS) ─────────────────────────────────────────────────
# How to find these:
#   1. Log in to https://incontrol2.peplink.com
#   2. client_id / client_secret: Settings → API → Create Client Application
#   3. org_id: visible in the URL after /o/ when browsing your organization
#   4. device IDs: Settings → API → Device Serial Numbers (or shown in device detail URL)

PEPLINK_CLIENT_ID=
PEPLINK_CLIENT_SECRET=
PEPLINK_ORG_ID=

# Serial number / device ID for each physical unit
PEPLINK_DEVICE_001=
PEPLINK_DEVICE_002=
PEPLINK_DEVICE_003=

# ─── Google Maps ──────────────────────────────────────────────────────────────
# Restrict the key to Maps JavaScript API + your domain in the Google Cloud Console
GOOGLE_MAPS_KEY=